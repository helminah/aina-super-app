{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/redflag.js": { "maxDuration": 30 },
    "api/nutrition.js": { "maxDuration": 30 }
  }
}
