# Supabase (optionnel — sans ces variables, mode démo local)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic (côté serveur UNIQUEMENT — pas de préfixe VITE_)
# Obtenir une clé : https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optionnel — choix du modèle par route (réduit le coût ~15× sur le chat).
# Par défaut : chat = Haiku 4.5, redflag/nutrition = Opus 4.7 (extended thinking).
# MODEL_CHAT=claude-haiku-4-5-20251001
# MODEL_REDFLAG=claude-opus-4-7
# MODEL_NUTRITION=claude-opus-4-7
# MODEL_NORMALIZE=claude-haiku-4-5-20251001
